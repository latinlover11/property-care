<footer class="footer">
  <div class="footer-content">
    <div class="footer-section">
      <h4>{{ site.name }}</h4>
      <p>Professional property maintenance serving {% for area in site.areas %}{{ area }}{% if not loop.last %}{{ ', and ' if loop.revindex == 2 else ', ' }}{% endif %}{% endfor %} with honest work and lasting results.</p>
      <div class="footer-socials">
        <a href="#" aria-label="Facebook"><svg class="icon icon-sm"><use href="#icon-facebook"/></svg></a>
        <a href="#" aria-label="Instagram"><svg class="icon icon-sm"><use href="#icon-instagram"/></svg></a>
        <a href="#" aria-label="Google Reviews"><svg class="icon icon-sm"><use href="#icon-review"/></svg></a>
      </div>
    </div>

    <div class="footer-section">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="{{ root }}index.html">Home</a></li>
        <li><a href="{{ root }}services.html">Services</a></li>
        <li><a href="{{ root }}portfolio.html">Portfolio</a></li>
        <li><a href="{{ root }}about.html">About</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Service Areas</h4>
      <ul>
        {% for area in site.areas %}
        <li><svg class="icon icon-sm"><use href="#icon-pin"/></svg>{{ area }}</li>
        {% endfor %}
      </ul>
    </div>

    <div class="footer-section">
      <h4>Business Hours</h4>
      <ul class="hours-list">
        <li>Monday – Friday: 7:00 AM – 6:00 PM</li>
        <li>Saturday: 8:00 AM – 5:00 PM</li>
        <li>Sunday: Closed</li>
      </ul>
      <div class="footer-contact" style="margin-top: 1.5rem;">
        <p><strong>Phone:</strong> <a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a></p>
        <p><strong>Email:</strong> <a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {{ site.year }} {{ site.name }} — {{ site.areas[0] }}, CO &nbsp;·&nbsp; All rights reserved</p>
  </div>
</footer>
