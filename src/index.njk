  <!-- GUARANTEE -->
  <section style="background:var(--straw); text-align:center;">
    <div class="section">
      <div style="max-width:640px; margin:0 auto;">
        <svg class="icon" style="width:3rem;height:3rem;color:var(--bark);margin-bottom:1rem;"><use href="#icon-shield"/></svg>
        <h2 class="section-title" style="margin-bottom:0.75rem;">100% Satisfaction <em>Guaranteed</em></h2>
        <p style="color:var(--warm-mid); font-size:1rem; line-height:1.7;">If you're not happy with the work, we'll make it right — no questions asked. Every job is backed by our promise of honest, reliable service.</p>
      </div>
    </div>
  </section>

<!-- CONTACT -->
  <section id="contact" style="background:var(--bark);">
    <style>
      #contact .contact-intro p { color: rgba(245,240,232,0.75); }
      #contact .contact-detail strong,
      #contact .contact-detail a,
      #contact .form-group label { color: var(--straw); }
      #contact .form-group input,
      #contact .form-group textarea { background: rgba(245,240,232,0.08); border-color: rgba(245,240,232,0.2); color: var(--straw); }
      #contact .form-group input::placeholder,
      #contact .form-group textarea::placeholder { color: rgba(245,240,232,0.4); }
      #contact .btn-primary { background: var(--straw); color: var(--bark); }
      #contact .btn-primary:hover { background: #e8ddd0; }
    </style>
    <div class="section">
      <p class="section-label" style="color:var(--clay);">Get In Touch</p>
      <h2 class="section-title" style="color:var(--straw);">Request a Free <em style="color:var(--clay);">Estimate</em></h2>
      <div class="contact-layout">
        <div class="contact-intro">
          <p>Need a quote for your next home or property maintenance project? Send a quick message and we'll respond promptly with availability and pricing.</p>
          <div class="contact-detail">
            <strong>Call</strong> <a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a>
          </div>
          <div class="contact-detail">
            <strong>Email</strong> <a href="mailto:{{ site.email }}">{{ site.email }}</a>
          </div>
        </div>
        <!-- Netlify form integration -->
        <form class="contact-form" name="contact" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="contact" />
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your full name" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" placeholder="{{ site.phoneDisplay }}">
            </div>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required>
          </div>
          <div class="form-group">
            <label for="message">Project Details</label>
            <textarea id="message" name="message" placeholder="Tell us about your project — scope, timing, any photos to share?"></textarea>
          </div>
          <button type="submit" class="btn-primary">Send Request</button>
        </form>
      </div>
    </div>
  </section>
  <!-- NEWSLETTER -->
  <section id="newsletter" style="background:var(--cream);">
    <style>
      #newsletter .newsletter-form input[type="email"] { background: #fff; border-color: #d4c9bc; color: var(--bark); }
      #newsletter .newsletter-form input[type="email"]::placeholder { color: #a89888; }
    </style>
    <div class="section" style="text-align:center; padding:4rem 2.5rem;">
      <p class="section-label">Stay Updated</p>
      <h2 class="section-title" style="color:var(--bark);">Get tips &amp; <em style="color:var(--clay);">updates</em></h2>
      <p style="color:var(--bark); font-size:1rem; max-width:500px; margin:1.5rem auto; opacity:0.7;">Join our mailing list for seasonal tips, discounts, and updates on new services.</p>
      <form class="newsletter-form" id="newsletterForm" name="newsletter" method="POST" data-netlify="true" data-aos="fade-up">
  <input type="hidden" name="form-name" value="newsletter" />
  <input type="email" name="email" placeholder="your@email.com" required>
  <button type="submit" class="btn-primary">Subscribe</button>
</form>
